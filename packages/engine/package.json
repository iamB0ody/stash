{
  "name": "@stash/engine",
  "version": "0.1.0",
  "description": "Stash engine — auto-detects platform and provides unified API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@stash/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "dependencies": {
    "@stash/core": "workspace:*",
    "@stash/platform-mac": "workspace:*",
    "@stash/platform-windows": "workspace:*",
    "@stash/platform-linux": "workspace:*"
  }
}
