{
  "name": "stashit",
  "private": true,
  "description": "Your disk is full of junk. Let's fix that.",
  "scripts": {
    "build": "nx run-many -t build",
    "dev": "nx run @stash/cli:dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "nx run-many -t typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "graph": "nx graph"
  },
  "devDependencies": {
    "@nx/js": "^20.5.0",
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "nx": "^20.5.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.1",
    "typescript": "~5.8.2",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": ">=22.0.0"
  }
}
